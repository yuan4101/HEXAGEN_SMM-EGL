<?xml version="1.0" encoding="UTF-8"?>
<p:Hexagon xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:p="http://a.b.c/x/y/Z" xsi:schemaLocation="http://a.b.c/x/y/Z hexagen.ecore">
  <core>
    <aggregates name="OrderAggregate">
      <values name="totalPrice" type="Double"/>
      <internalEntities name="OrderLine">
        <values name="quantity" type="Integer"/>
        <attributes name="ProductDetails">
          <values name="sku" type="String"/>
        </attributes>
      </internalEntities>
      <attributes name="ShippingAddress">
        <values name="city" type="String"/>
        <values name="street" type="String"/>
      </attributes>
    </aggregates>
  </core>
  <ports xsi:type="p:InboundPort" name="OrderInputPort"/>
  <ports xsi:type="p:OutboundPort" name="OrderRepositoryPort"/>
  <adapters xsi:type="p:InboundAdapter" name="OrderRestController" targetPort="//@ports.0"/>
  <adapters xsi:type="p:OutboundAdapter" name="OrderJpaAdapter" targetPort="//@ports.1"/>
  <services name="OrderApplicationService" exposedThrough="//@ports.0" coordinates="//@core/@aggregates.0" calls="//@ports.1">
    <useCases name="placeNewOrder"/>
  </services>
</p:Hexagon>
